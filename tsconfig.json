<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bolão Mundial 2026</title>
    <script>
      // GitHub Pages SPA fix — rafael.github.io/spa-github-pages technique
      (function() {
        var search = window.location.search;
        if (search.length > 1) {
          // Converte ?/bolao-copa-2026/admin → /bolao-copa-2026/admin
          var decoded = search.slice(1).replace(/~and~/g, '&');
          if (decoded.indexOf('/') === 0) {
            window.history.replaceState(null, null, decoded);
          }
        }
      })();
    </script>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/main.tsx"></script>
  </body>
</html>
